# Copy to .env next to docker-compose (or export in shell). Do not commit real secrets.
# See README "Environment" and docs/deploy-docker.md.

# Required for persistence
MESH2CAD_STATE_DIR=/data/state

# API bind (containers)
MESH2CAD_BIND_HOST=0.0.0.0
MESH2CAD_BIND_PORT=8000

# Host port mapping (docker-compose.yml)
MESH2CAD_HOST_PORT=8000

# Production: require API keys on /v1, legacy /process*, and /metrics (when METRICS_ENABLED)
# MESH2CAD_API_KEYS=key1,key2

# Dev only: allow JSON input_path outside MESH2CAD_STATE_DIR (do not use in production)
# MESH2CAD_RELAX_INPUT_PATH_GUARD=1

# HTTPS behind reverse proxy
# MESH2CAD_SECURE_COOKIES=true

# Optional: Redis queue + workers (use docker-compose.queue.yml)
# MESH2CAD_JOB_BACKEND=rq
# MESH2CAD_REDIS_URL=redis://redis:6379/0
# MESH2CAD_RQ_QUEUE=mesh2cad

# Optional: shared rate limits across API replicas
# MESH2CAD_RATE_LIMIT_BACKEND=redis
# MESH2CAD_RATE_LIMIT_PER_MINUTE=120

# Optional: build-time extras (docker compose build args)
# MESH2CAD_PIP_EXTRAS=api,queue

# Kubernetes bundle (Redis + RQ + combined API/worker Pod): deploy/k8s/README.md
# kubectl apply -k deploy/k8s
